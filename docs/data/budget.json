  "quotes": [
    {
      "text": "Spending in the areas of K-12 and Health and Human Resources represents 62% of the state's total biennial operational budget.",
      "topic": "Spending priorities",
      "principle": "Just two areas drive nearly two-thirds of operating spending.",
      "source_stem": "overview_2024_fy2024-2026",
      "page": 8,
      "doc_title": "An Overview of Virginia's Biennial Budget FY 2024-2026",
      "as_of": "2024-05-31"
    },
    {
      "text": "Chapter 2 includes general fund spending totaling $63.7 billion over the biennium with $31.8 billion in FY 2025 and $32.0 billion in FY 2026 in operating expenditures.",
      "topic": "General Fund spending",
      "principle": "The enacted FY2024-2026 general fund operating budget.",
      "source_stem": "overview_2024_fy2024-2026",
      "page": 8,
      "doc_title": "An Overview of Virginia's Biennial Budget FY 2024-2026",
      "as_of": "2024-05-31"
    },
    {
      "text": "Children's Services Act (CSA) Forecast. Adds $37.0 million in FY 2025 and $63.3 million in FY 2026 for estimated caseload and cost increases in CSA.",
      "topic": "Health & Human Resources",
      "principle": "Caseload-driven forecasts push HHR spending up in the amended budget.",
      "source_stem": "overview_2025_ch725",
      "page": 9,
      "doc_title": "Overview of Virginia's Budget for FY 2024-2026 (Chapter 725)",
      "as_of": "2025-05-19"
    },
    {
      "text": "51.1% of general fund appropriations are for K-12 and Medicaid",
      "topic": "Where the money goes",
      "principle": "K-12 and Medicaid alone are over half the general fund.",
      "source_stem": "virginia_in_focus_2026",
      "page": 17,
      "doc_title": "Virginia in Focus: Budget and Outcomes for Core Government Areas",
      "as_of": "2026-01-15"
    },
    {
      "text": "The top 10 general fund appropriations total $24.4 billion, or 72.3% of the general fund budget",
      "topic": "Concentration of spending",
      "principle": "Ten line items account for nearly three-quarters of the general fund.",
      "source_stem": "virginia_in_focus_2026",
      "page": 17,
      "doc_title": "Virginia in Focus: Budget and Outcomes for Core Government Areas",
      "as_of": "2026-01-15"
    },
    {
      "text": "The personal income tax provides about 63% of General Fund revenues",
      "topic": "Where the money comes from",
      "principle": "The general fund leans heavily on a single revenue source.",
      "source_stem": "virginia_in_focus_2026",
      "page": 17,
      "doc_title": "Virginia in Focus: Budget and Outcomes for Core Government Areas",
      "as_of": "2026-01-15"
    },
    {
      "text": "HB 30 as introduced included $71.5 billion in total general fund resources",
      "topic": "FY2026-2028 resources",
      "principle": "The next biennium opens with materially larger general fund resources.",
      "source_stem": "conf_report_hb30_2026",
      "page": 4,
      "doc_title": "HB 30 Conference Report (FY 2026-2028 Biennial Budget)",
      "as_of": "2026-06-22"
    },
    {
      "text": "Conference Report includes Part 3 language - applicable for this biennium only - establishing a rate of $0.011/kWh of all electricity consumed at each data center per month",
      "topic": "Data centers",
      "principle": "A first-of-its-kind energy consumption fee targeting data centers.",
      "source_stem": "conf_report_hb30_2026",
      "page": 5,
      "doc_title": "HB 30 Conference Report (FY 2026-2028 Biennial Budget)",
      "as_of": "2026-06-22"
    },
    {
      "text": "Annual revenue collections are capped at $600 million per year",
      "topic": "Data centers",
      "principle": "The new data-center fee is capped, with overages refunded pro-rata.",
      "source_stem": "conf_report_hb30_2026",
      "page": 5,
      "doc_title": "HB 30 Conference Report (FY 2026-2028 Biennial Budget)",
      "as_of": "2026-06-22"
    },
    {
      "text": "Reflects revenue reduction of $51.0 million in the first year and $120.0 million in the second year to reflect increasing the standard deduction",
      "topic": "Tax relief",
      "principle": "A standard-deduction increase trades revenue for household tax relief.",
      "source_stem": "conf_report_hb30_2026",
      "page": 6,
      "doc_title": "HB 30 Conference Report (FY 2026-2028 Biennial Budget)",
      "as_of": "2026-06-22"
    },
    {
      "text": "Unemployment has been rising in Virginia and its regions since the beginning of 2025 with statewide unemployment reaching 3.5% in September from 3% in January 2025.",
      "topic": "Economy",
      "principle": "A softening labor market is the backdrop to the next budget.",
      "source_stem": "virginia_in_focus_2026",
      "page": 12,
      "doc_title": "Virginia in Focus: Budget and Outcomes for Core Government Areas",
      "as_of": "2026-01-15"
    }
  ],
