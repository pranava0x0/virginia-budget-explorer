# Secrets / env
.env
.env.local
credentials.json
secrets/

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store

# Local dev tooling (preview server config; absolute paths, not portable)
.claude/

# Large cached source PDFs are regenerable via scripts/scrape.py.
# Keep them out of git; the manifest (URL + sha256) is the source of truth.
sources/raw/*.pdf

# Human-readable paged dumps are regenerable; the .pages.json evidence (read by
# the test suite to verify every quote/number) IS committed so the repo
# self-verifies on a fresh clone.
data/text/*.txt

# Candidate-quote triage output (scripts/find_quotes.py) is a scratch review
# queue for picking quotes into build_data.py -- cheaply regenerable from the
# committed .pages.json + .sections.json and not read by the build or tests.
# *.sections.json is NOT ignored: it comes from the raw PDF's bookmarks
# (scripts/section.py), which aren't preserved anywhere else in the repo since
# sources/raw/*.pdf itself is gitignored -- without committing it, a fresh
# checkout couldn't regenerate it without re-downloading the PDF.
data/derived/*.candidate_quotes.json
